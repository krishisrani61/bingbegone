{
  "manifest_version": 3,

  "name": "BingBeGone",
  "short_name": "BingBeGone",

  "description": "Redirect Bing searches to your preferred search engine.",

  "version": "0.1.0",

  "permissions": [
    "storage",
    "webNavigation"
  ],
  "web_accessible_resources": [
  {
    "resources": [
      "assets/*"
    ],
    "matches": [
      "<all_urls>"
    ]
  }
]

  "host_permissions": [
    "https://www.bing.com/*",
    "https://bing.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "options_page": "pages/options.html",

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BingBeGone"
  },

  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
