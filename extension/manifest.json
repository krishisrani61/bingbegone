{
  "manifest_version": 3,
  "name": "BingBeGone",
  "description": "Redirect Bing searches to your preferred search engine.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.bing.com/*",
    "https://bing.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "pages/options.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BingBeGone"
  }
}
